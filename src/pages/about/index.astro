  {/* projects */}
  <h2 id='projects'>Projects</h2>
  <p>一些我做过的小项目，点击可跳转：</p>
  <ToolSection
    class='mb-5'
    title='Labs'
    tools={[
      {
        name: 'Whistle Daily',
        description: '个人定制日报',
        href: 'https://daily.bolaxious.cn/',
        icon: import('@/assets/tools/projects/num-1.svg?raw')
      },
      {
        name: 'BemoLens',
        description: '多证据 AI 图片检测',
        href: 'https://bemolens.vercel.app/',
        icon: import('@/assets/tools/projects/num-2.svg?raw')
      },
      {
        name: 'Bemo Bio',
        description: '个人主页 / Bio',
        href: 'https://bemo-bio.bolaxious.cn/',
        icon: import('@/assets/tools/projects/num-3.svg?raw')
      }
    ]}
  />

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>（WIP）下面是一些我正在使用的工具，如果你感兴趣的话，可以试试点击对应的icon：</p>
  <ToolSection
    class='mb-5'
    title='Design'
    tools={[
      {
        name: 'Figma',
        description: 'UI Design',
        href: 'https://www.figma.com/',
        icon: import('@/assets/tools/figma.svg?raw')
      },
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Notion',
        description: 'Note Taking',
        href: 'https://www.notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      },
      {
        name: 'Typora',
        description: 'Markdown Editor',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Windows 11',
        description: 'Framework Laptop 16',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>
    Coding or Playing games
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/Mengbooo',
        text: 'followers',
        api: 'github/Mengbooo'
      },
      {
        platform: 'Steam',
        icon: 'steam',
        color: '#50769d',
        link: 'https://steamcommunity.com/profiles/76561199580205777',
        text: 'games',
        api: 'steamgames/76561199580205777'
      }
    ]}
  />

